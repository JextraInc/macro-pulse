# Required. Discord webhook URL (https://discord.com/api/webhooks/<id>/<token>).
# Create at: Server Settings → Integrations → Webhooks → New Webhook.
DISCORD_WEBHOOK_URL=

# Poll cadence in seconds. Lower = faster detection, higher = lower rate-limit
# risk. Minimum 5. Default 60.
POLL_INTERVAL_SECONDS=60

# VADER compound ceiling for an alert. Range: [-1.0, 0.0]. More negative =
# stricter. A post triggers an alert only if it matches a keyword AND its
# compound score is strictly below this threshold. Default -0.6.
SENTIMENT_THRESHOLD=-0.6

# Keywords (JSON list). Any match + below-threshold sentiment fires an alert.
# Multi-word entries use substring match; single-word entries use word
# boundaries. On multiple matches, first-in-list wins.
BEARISH_KEYWORDS=["shoot and kill","mining","blockade","seized","devastate","no peace","missile","retaliation","oil embargo","strait closed"]

# Truth Social handles to poll (JSON list). Leave [] to disable Truth Social.
TRUTHSOCIAL_HANDLES=["realDonaldTrump"]

# Nitter instance pool (JSON list). Tried in order; first 2xx wins. If the full
# pool fails, the provider logs a warning and the loop continues.
NITTER_INSTANCES=["https://nitter.net","https://nitter.privacydev.net"]

# X / Twitter handles to poll via Nitter (JSON list). Leave [] to disable
# Nitter entirely.
NITTER_HANDLES=[]

# SQLite dedup DB path. Parent directory is auto-created on startup.
DEDUP_DB_PATH=./data/seen.db

# Drop dedup entries older than N days on startup. Default 7.
DEDUP_TTL_DAYS=7

# Log verbosity: DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO

# httpx timeout (seconds) for all outbound HTTP requests.
HTTP_TIMEOUT_SECONDS=15.0

# User-Agent string sent to Truth Social, Nitter, and Discord.
USER_AGENT=MacroPulseSPX/1.0
